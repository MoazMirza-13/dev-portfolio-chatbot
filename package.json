{
  "name": "react-portfolio-chatbot",
  "description": "",
  "version": "0.1.0",
  "main": "dist/react/chatbot-widget.umd.js",
  "module": "dist/react/chatbot-widget.es.js",
  "types": "dist/react/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/chatbot-widget.es.js",
      "require": "./dist/react/chatbot-widget.umd.js"
    },
    "./vanilla": {
      "import": "./dist/vanilla/chatbot-widget.vanilla.js"
    }
  },
  "scripts": {
    "build:css": "npx @tailwindcss/cli -i ./src/styles.css -o ./src/tailwind.css",
    "build:react": "vite build --config vite.config.react.ts",
    "build:vanilla": "vite build --config vite.config.vanilla.ts",
    "build:all": "npm run build:css && npm run build:react && npm run build:vanilla"
  },
  "peerDependencies": {
    "react": ">=16",
    "react-dom": ">=16"
  },
  "dependencies": {
    "@google/genai": "^1.19.0",
    "@radix-ui/react-slot": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "js-levenshtein": "^1.1.6",
    "lucide-react": "^0.544.0",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.3.8"
  },
  "devDependencies": {
    "@r2wc/react-to-web-component": "^2.1.0",
    "@types/js-levenshtein": "^1.1.3",
    "@types/node": "^24.5.1",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.0.3",
    "dotenv": "^17.2.2",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-dts": "^4.5.4"
  }
}
