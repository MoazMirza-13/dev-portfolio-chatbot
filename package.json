{
  "name": "dev-portfolio-chatbot",
  "description": "An AI-powered chatbot for developers portfolio websites",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "scripts"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vanilla": {
      "import": "./dist/vanilla/chatbot-widget.vanilla.js"
    }
  },
  "scripts": {
    "build:css": "npx @tailwindcss/cli -i ./src/styles.css -o ./src/tailwind.css",
    "build:react": "bunchee src/index.react.ts -o dist/index.js --format esm --target es2020 --sourcemap",
    "build:vanilla": "vite build --config vite.config.vanilla.ts",
    "build:all": "pnpm run build:css && pnpm run build:react && pnpm run build:vanilla",
    "build": "pnpm run build:all && pnpm --filter website run build",
    "dev": "pnpm dlx concurrently \"npx @tailwindcss/cli -i ./src/styles.css -o ./src/tailwind.css --watch\" \"pnpm --filter website run dev\"",
    "postinstall": "node ./scripts/createConfig.js",
    "prepare": "husky"
  },
  "lint-staged": {
    "website/**/*.{js,ts,jsx,tsx,css}": [
      "pnpm --filter website lint --fix"
    ]
  },
  "peerDependencies": {
    "react": ">=16",
    "react-dom": ">=16"
  },
  "dependencies": {
    "@google/genai": "^1.19.0",
    "@radix-ui/react-slot": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "js-levenshtein": "^1.1.6",
    "lucide-react": "^0.544.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.3.8"
  },
  "devDependencies": {
    "@r2wc/react-to-web-component": "^2.1.0",
    "@types/js-levenshtein": "^1.1.3",
    "@types/node": "^24.5.1",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.0.3",
    "bunchee": "^6.6.0",
    "dotenv": "^17.2.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.3",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-plugin-css-injected-by-js": "^3.5.2"
  }
}
